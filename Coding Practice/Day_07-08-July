#Day-07 - Automating Cloud Infrastructure with terraform and Ansible
#Ansible-Setup Nginx with custom Config
- name: Setup Nginx with Custom Config
  yum:
    name: Nginx
    state: present
- name: Copy custom nginx.Confi
  copy:
    src: nginx
    state: present
- name: Start nginx service
  services:
    name: nginx
    state: started
    enabled: yes

#Terraform - Provision EC2 with IAM Role
resource "aws_iam_role" "ec2_role" {
  name                = "pathnex_ec2_role"
  assume_role_policy  = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
          }
          ]
          }
          ]
          }
          )
          }

