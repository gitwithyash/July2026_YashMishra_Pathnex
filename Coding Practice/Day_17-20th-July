  stage: deploy
  script:
    - kubectl --context=aws-cluster apply -f kubernetes/deployment.yaml

deploy_azure:
  stage: deploy
  script:
    - kubectl --context=azure-cluster apply -f kubernetes/deployment.yaml
 

