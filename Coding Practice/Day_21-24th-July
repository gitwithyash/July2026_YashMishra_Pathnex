## GitLab CI/CD Pipeline For Backup and Restore Deplyment Files
stage:
    - backup
    - restore

backup:
    stage: backup
    script:
        - tar -czvf /tmp/backup.tar.gz kubernetes/deployment.yaml
        
restore:
    stage: restore
    script:
        - tar -xzvf /tmp/backup.tar.gz -C kubernetes/        

