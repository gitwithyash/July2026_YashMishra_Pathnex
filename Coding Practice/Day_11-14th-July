## Ansible - Install Helm on Server
- name: Install Helm
  get_url:
    url: https://get.helm.sh/helm-v3.7.0-linux-amd64.tar.gz
    dest: /tmp/helm/tar/gz

- name: Extract Helm
  unarchive:
    src: /tmp/helm/tar.gz

- name: set Helm binary permissions
  file:
    path: /usr/local/bin/helm
    mode: '0755'

